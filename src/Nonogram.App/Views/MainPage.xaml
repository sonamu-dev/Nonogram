<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nonogram.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <NavigationView
            x:Name="RootNavigationView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="OnNavigationSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Play" Icon="Play" Tag="PlayPage" />
                <NavigationViewItem Content="Library" Icon="Library" Tag="LibraryPage" />
                <NavigationViewItem Content="Generate" Icon="Refresh" Tag="GeneratePage" />
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="SettingsPage" />
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Page>
